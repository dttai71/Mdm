# MDM — .env.example (SDLC 6.4.0 LITE required)
# Copy to .env (chmod 660 ITteam) — NEVER commit .env to git
# Per §R-71 service account discipline: rotation cadence ≤ 90 days

# ============================================================
# APPLICATION
# ============================================================
APP_NAME=mdm
APP_ENV=development        # development | staging | production
APP_DEBUG=true             # false in production
APP_PORT=5050              # FastAPI default
SECRET_KEY=__GENERATE_RANDOM_FERNET_KEY__   # for JWT signing + CSRF

# ============================================================
# DATABASE — write side (PostgreSQL on S2 LXC 210)
# ============================================================
POSTGRES_HOST=192.168.2.10
POSTGRES_PORT=5432
POSTGRES_DB=mdm
POSTGRES_USER=mdm_app
POSTGRES_PASSWORD=__SET_VIA_VAULT__

# ============================================================
# DATABASE — read side (ClickHouse NQH for COGS engine + dim_* reads)
# ============================================================
CLICKHOUSE_HOST=192.168.2.10
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=admin
CLICKHOUSE_PASSWORD=__SET_VIA_VAULT__
CLICKHOUSE_DATABASE=NQH

# ============================================================
# CACHE / RECORD-LOCK (Redis on S2 LXC 210)
# ============================================================
REDIS_HOST=192.168.2.10
REDIS_PORT=6379
REDIS_DB=10                # MDM dedicated DB (avoid collisions w/ other services)
REDIS_PASSWORD=__SET_VIA_VAULT__

# ============================================================
# GOOGLE DRIVE — Excel V2 SSOT sync (read-only)
# ============================================================
GOOGLE_SERVICE_ACCOUNT_PATH=/home/nqh/shared/models/core/ops/config/secrets/nqh-sheet-reader.json
GOOGLE_DRIVE_SHEET_ID=1K-SL4aeorrZtgvoTiOxarC_sNRewktAi
GOOGLE_DRIVE_POLL_INTERVAL_SEC=900   # 15-min poll cadence (matches CukCuk scraper)

# ============================================================
# TELEGRAM — alerts to NQH-Ops-Team
# ============================================================
TELEGRAM_API_ENDPOINT=https://mtclaw.nhatquangholding.com/v1/send
TELEGRAM_API_TOKEN=__BEARER_TOKEN_VIA_VAULT__
TELEGRAM_CHANNEL=telegram             # mtsclawbot (verified member NQH-Ops-Team)
TELEGRAM_CHAT_ID=-5342609783          # NQH-Ops-Team pod

# ============================================================
# RBAC OWNERS (per @mis Decision Log)
# ============================================================
# Role mapping → person (per feedback_role_based_org_design)
RBAC_OWNER_MDG002_SUPPLIER=ms_hong
RBAC_OWNER_MDG003_PRODUCT=thy
RBAC_OWNER_MDG004_SITE=ms_hong
RBAC_OWNER_MDG005_CUSTOMER=thy
RBAC_OWNER_MDG008_FOOD=thy
RBAC_OWNER_MDG011_COST=ktt
RBAC_OWNER_MDG012_EQUIPMENT=hao

# ============================================================
# LOG + MONITORING
# ============================================================
LOG_LEVEL=INFO            # DEBUG | INFO | WARN | ERROR
LOG_PATH=/var/log/mdm
SENTRY_DSN=               # optional (post-MVP)

# ============================================================
# FEATURE FLAGS (per MM#9 ON-DEMAND markers — flip when triggered)
# ============================================================
FEATURE_PHASE2_ONLINE_DASHBOARD=false   # ON-DEMAND post MVP-prove
FEATURE_PHASE2_MDG009_ONLINE=false      # ON-DEMAND post MVP-prove
FEATURE_PHASE2_PRICE_LOOP=false         # ON-DEMAND post VAT POC PASS
FEATURE_PHASE3_CASH_CONSOL=false        # CARVE → BFlow 2 (NOT MDM scope)
