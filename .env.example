# MDM — .env.example (SDLC 6.4.0 LITE required)
# Copy to .env (chmod 660 ITteam) — NEVER commit .env to git
# Per §R-71 service account discipline: rotation cadence ≤ 90 days

# ============================================================
# APPLICATION
# ============================================================
APP_NAME=mdm
APP_ENV=development
APP_DEBUG=true
APP_PORT=5050
SECRET_KEY=__GENERATE_RANDOM_FERNET_KEY__

# ============================================================
# DATABASE — write (PostgreSQL on S2 LXC 210)
# ============================================================
POSTGRES_HOST=192.168.2.10
POSTGRES_PORT=5432
POSTGRES_DB=mdm
POSTGRES_USER=mdm_app
POSTGRES_PASSWORD=__SET_VIA_VAULT__

# ============================================================
# DATABASE — read (ClickHouse NQH for COGS engine)
# ============================================================
CLICKHOUSE_HOST=192.168.2.10
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=admin
CLICKHOUSE_PASSWORD=__SET_VIA_VAULT__
CLICKHOUSE_DATABASE=NQH

# ============================================================
# CACHE / RECORD-LOCK (Redis on S2 LXC 210)
# ============================================================
REDIS_HOST=192.168.2.10
REDIS_PORT=6379
REDIS_DB=10
REDIS_PASSWORD=__SET_VIA_VAULT__
LOCK_TTL_SEC=900       # 15-min record-lock per ADR-002 §2.5
LOCK_HEARTBEAT_SEC=300 # client heartbeat 5-min

# ============================================================
# GOOGLE DRIVE — Excel V2 SSOT sync (read-only, born-clean v2)
# ============================================================
GOOGLE_SERVICE_ACCOUNT_PATH=/home/nqh/shared/models/core/ops/config/secrets/nqh-sheet-reader.json
GOOGLE_DRIVE_SHEET_ID=1K-SL4aeorrZtgvoTiOxarC_sNRewktAi
GOOGLE_DRIVE_POLL_INTERVAL_SEC=900

# ============================================================
# TELEGRAM — alerts to NQH-Ops-Team (per WI-105 §5.1 tier)
# ============================================================
TELEGRAM_API_ENDPOINT=https://mtclaw.nhatquangholding.com/v1/send
TELEGRAM_API_TOKEN=__BEARER_TOKEN_VIA_VAULT__
TELEGRAM_CHANNEL=telegram             # mtsclawbot (verified NQH-Ops-Team member)
TELEGRAM_CHAT_ID=-5342609783          # NQH-Ops-Team pod

# ============================================================
# RBAC — managed via mdm_user_roles TABLE per ADR-002 + SPEC-004
# (NOT .env hardcode — em correct prior placeholder)
# ============================================================
# Initial admin user (bootstrap only — seed via 002_seed_rbac.sql)
BOOTSTRAP_ADMIN_USER=dvhiep
BOOTSTRAP_ADMIN_ROLES=ROLE_CIO,ROLE_MDT_ADMIN

# ============================================================
# AUTHENTICATION (JWT)
# ============================================================
JWT_ALGORITHM=HS256       # dev; RS256 in prod
JWT_EXPIRY_HOURS=8
JWT_REFRESH_EXPIRY_DAYS=30

# ============================================================
# LOG + MONITORING
# ============================================================
LOG_LEVEL=INFO
LOG_PATH=/var/log/mdm
SENTRY_DSN=               # optional (post-MVP)

# ============================================================
# FEATURE FLAGS (per Mental Model #9 ON-DEMAND markers)
# ============================================================
FEATURE_PHASE2_ONLINE_DASHBOARD=false   # ON-DEMAND post MVP-prove
FEATURE_PHASE2_MDG009_ONLINE=false      # ON-DEMAND post MVP-prove
FEATURE_PHASE2_PRICE_LOOP=false         # ON-DEMAND post VAT POC PASS
FEATURE_PHASE3_CASH_CONSOL=false        # CARVE → BFlow 2 (NOT MDM scope)
